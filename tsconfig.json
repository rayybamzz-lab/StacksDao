{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "declaration": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "packages/**/*.ts"
    ],
    "exclude": [
        "packages/**/dist",
        "frontend",
        "node_modules",
        "tests"
    ]
}
